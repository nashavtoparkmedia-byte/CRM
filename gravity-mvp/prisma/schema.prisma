generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiConnection {
  id        String   @id @default(cuid())
  clid      String
  apiKey    String
  parkId    String
  createdAt DateTime @default(now())
  logs      ApiLog[]
}

model ApiLog {
  id           String        @id @default(cuid())
  connectionId String
  method       String
  requestUrl   String
  requestBody  String?
  responseBody String?
  statusCode   Int
  error        String?
  durationMs   Int
  createdAt    DateTime      @default(now())
  connection   ApiConnection @relation(fields: [connectionId], references: [id])
}

model TelegramConnection {
  id            String   @id @default(cuid())
  apiId         Int
  apiHash       String
  sessionString String?
  isActive      Boolean  @default(false)
  phoneNumber   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDefault     Boolean  @default(false)
  name          String?
}

model MaxConnection {
  id        String   @id
  name      String?
  botToken  String
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Channel profile для водителя в MAX — не identity-модель, не замена Contact
// maxExternalUserId / maxExternalChatId без @unique до завершения discovery
model DriverMax {
  id                  String   @id @default(cuid())
  driverId            String   @unique
  maxExternalUserId   String?  // stable user id — заполнится после Фазы 0
  maxExternalChatId   String?  // chat/dialog id — может отличаться от user id
  phone               String?
  name                String?
  createdAt           DateTime @default(now())

  driver              Driver   @relation(fields: [driverId], references: [id])

  @@index([maxExternalUserId])
  @@index([maxExternalChatId])
}

// Настройки личной сессии MAX (QR-авторизация)
// Одна запись = одна активная сессия
model MaxPersonalSession {
  id                      String                   @id @default(cuid())

  // Что выбрал пользователь при подключении
  historyImportMode       MaxHistoryImportMode     @default(from_connection_time)

  // Когда была выполнена QR-авторизация
  connectedAt             DateTime?

  // Что реально смог транспорт (заполняется после Фазы 0.1)
  historySyncModeResolved MaxHistorySyncMode?

  // Состояние процесса синхронизации
  historySyncStatus       MaxHistorySyncStatus     @default(not_started)

  // Когда завершилась начальная синхронизация
  initialSyncCompletedAt  DateTime?

  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

enum MaxHistoryImportMode {
  none                  // Не импортировать историю
  from_connection_time  // Только новые сообщения с момента подключения
  available_history     // Импортировать доступную историю
}

enum MaxHistorySyncMode {
  live_only         // Mode C — только live events
  partial_backfill  // Mode B — частичная история
  full_backfill     // Mode A — полная доступная история
}

enum MaxHistorySyncStatus {
  not_started
  running
  completed
  partial   // завершён, но история была ограничена транспортом
  failed
}

model WhatsAppConnection {
  id          String                   @id @default(cuid())
  name        String?
  status      WhatsAppConnectionStatus @default(idle)
  phoneNumber String?
  sessionData String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  chats       WhatsAppChat[]
}

model WhatsAppChat {
  id            String             @id
  connectionId  String
  name          String?
  lastMessageAt DateTime?
  connection    WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages      WhatsAppMessage[]

  @@unique([id, connectionId])
}

model WhatsAppMessage {
  id            String              @id
  chatId        String
  body          String
  fromMe        Boolean
  timestamp     DateTime
  type          WhatsAppMessageType @default(chat)
  mediaPath     String?
  isMediaLoaded Boolean             @default(false)
  mediaSize     Int?
  chat          WhatsAppChat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([id, chatId])
}

model DriverTelegram {
  id            String   @id @default(cuid())
  driverId      String   @unique
  telegramId    BigInt   @unique
  username      String?
  phoneVerified Boolean  @default(false)
  botState      String   @default("IDLE")
  carId         String?
  carLabel      String?
  createdAt     DateTime @default(now())
}

model BotChatMessage {
  id         String   @id @default(cuid())
  telegramId BigInt
  driverId   String?
  direction  String
  text       String
  createdAt  DateTime @default(now())
}

model Bot {
  id              String           @id @default(uuid())
  token           String           @unique
  name            String
  username        String?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  analyticsEvents AnalyticsEvent[]
  broadcasts      Broadcast[]
  surveys         Survey[]
  users           User[]

  @@map("bots")
}

model Survey {
  id            String     @id @default(uuid())
  botId         String     @map("bot_id")
  title         String     @default("Новый опрос")
  triggerButton String     @default("📊 Опрос качества") @map("trigger_button")
  isActive      Boolean    @default(true) @map("is_active")
  isLinear      Boolean    @default(true) @map("is_linear")
  googleSheetId String?    @map("google_sheet_id")
  syncMode      String     @default("ON_COMPLETE") @map("sync_mode")
  createdAt     DateTime   @default(now()) @map("created_at")
  archivedAt    DateTime?  @map("archived_at")
  questions     Question[]
  bot           Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("surveys")
}

model Question {
  id           String   @id @default(uuid())
  surveyId     String   @map("survey_id")
  order        Int      @default(0)
  type         String
  text         String
  options      Json?
  isRequired   Boolean  @default(true) @map("is_required")
  isConversion Boolean  @default(false) @map("is_conversion")
  routingRules Json?    @map("routing_rules")
  answers      Answer[]
  survey       Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model User {
  id                String           @id @default(uuid())
  botId             String           @map("bot_id")
  telegramId        BigInt           @map("telegram_id")
  username          String?
  firstName         String?          @map("first_name")
  currentQuestionId String?          @map("current_question_id")
  status            String           @default("ACTIVE")
  createdAt         DateTime         @default(now()) @map("created_at")
  analyticsEvents   AnalyticsEvent[]
  answers           Answer[]
  bot               Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, telegramId])
  @@map("users")
}

model Answer {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  value      String
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("answers")
}

model AnalyticsEvent {
  id        String             @id @default(uuid())
  botId     String             @map("bot_id")
  userId    String?            @map("user_id")
  eventType AnalyticsEventType @map("event_type")
  sourceId  String?            @map("source_id")
  metadata  Json?
  createdAt DateTime           @default(now()) @map("created_at")
  bot       Bot                @relation(fields: [botId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id])

  @@index([botId, createdAt])
  @@index([botId, eventType, createdAt])
  @@map("analytics_events")
}

model Broadcast {
  id            String         @id @default(uuid())
  botId         String         @map("bot_id")
  text          String
  status        String         @default("PENDING")
  totalTargeted Int            @default(0) @map("total_targeted")
  createdAt     DateTime       @default(now()) @map("created_at")
  completedAt   DateTime?      @map("completed_at")
  stats         BroadcastStat?
  bot           Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("broadcasts")
}

model BroadcastStat {
  id           String    @id @default(uuid())
  broadcastId  String    @unique @map("broadcast_id")
  successCount Int       @default(0) @map("success_count")
  failedCount  Int       @default(0) @map("failed_count")
  broadcast    Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@map("broadcast_stats")
}

model Driver {
  id                   String               @id @default(cuid())
  yandexDriverId       String               @unique
  fullName             String
  phone                String?
  licenseNumber        String?
  lastExternalPark     String?
  lastFleetCheckAt     DateTime?
  lastFleetCheckStatus String?
  lastFleetCheckId     String?
  segment              String               @default("unknown")
  segmentOverride      String?
  statusOverride       String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  score                Float?
  dismissedAt          DateTime?
  hiredAt              DateTime?
  lastOrderAt          DateTime?
  customFields         Json?                @default("{}")
  primaryYandexId      String?              @unique
  chats                Chat[]
  communicationEvents  CommunicationEvent[]
  attentions           DriverAttention[]
  daySummaries         DriverDaySummary[]
  events               DriverEvent[]
  managerTasks         ManagerTask[]
  tasks                Task[]
  maxProfile           DriverMax?

  @@index([fullName])
  @@index([segment])
  @@index([primaryYandexId])
}

model Chat {
  id               String      @id @default(cuid())
  driverId         String?
  channel          ChatChannel
  externalChatId   String      @unique
  name             String?
  lastMessageAt    DateTime?
  unreadCount      Int         @default(0)
  metadata         Json?       @default("{}")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  requiresResponse Boolean     @default(false)
  status           String      @default("new")
  driver           Driver?     @relation(fields: [driverId], references: [id])
  messages         Message[]

  @@index([driverId])
  @@index([lastMessageAt(sort: Desc)])
  @@index([status])
}

model Message {
  id          String              @id @default(cuid())
  chatId      String
  direction   MessageDirection
  type        MessageType         @default(text)
  content     String
  status      MessageStatus       @default(sent)
  aiStatus    AiStatus?
  channel     ChatChannel?        @default(whatsapp)
  externalId  String?             @unique
  metadata    Json?               @default("{}")
  sentAt      DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  chat        Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  attachments MessageAttachment[]
  eventLogs   MessageEventLog[]

  @@index([chatId, sentAt(sort: Desc)])
  @@index([externalId])
  @@index([aiStatus])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  type      String
  url       String
  fileName  String?
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessageEventLog {
  id        String   @id @default(cuid())
  messageId String
  eventType String
  status    String   @default("pending")  // pending | processing | processed | failed
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
  @@index([status, eventType])
}

model DriverEvent {
  id        String   @id @default(cuid())
  driverId  String
  eventType String
  payload   Json?
  createdBy String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])

  @@index([driverId, createdAt])
  @@index([eventType])
}

model DriverAttention {
  id         String    @id @default(cuid())
  driverId   String
  reason     String
  riskLevel  String    @default("medium")
  status     String    @default("open")
  meta       Json?
  createdBy  String?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  driver     Driver    @relation(fields: [driverId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([driverId])
}

model DriverDaySummary {
  id                String   @id @default(cuid())
  driverId          String
  date              DateTime @db.Date
  tripCount         Int      @default(0)
  hadManagerMessage Boolean  @default(false)
  hadManagerCall    Boolean  @default(false)
  hadAutoMessage    Boolean  @default(false)
  hadPromotion      Boolean  @default(false)
  hadAiAction       Boolean  @default(false)
  hadGoalAchieved   Boolean  @default(false)
  driver            Driver   @relation(fields: [driverId], references: [id])

  @@unique([driverId, date])
  @@index([date])
  @@index([driverId, date])
}

model ScoringThreshold {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Int
  updatedAt DateTime @updatedAt
}

model CommunicationEvent {
  id        String   @id @default(cuid())
  driverId  String
  channel   String
  direction String
  eventType String
  content   String?
  metadata  Json?
  createdBy String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])

  @@index([driverId, createdAt(sort: Desc)])
  @@index([eventType])
}

model CommunicationTrigger {
  id              String   @id @default(cuid())
  name            String
  condition       String
  threshold       Int
  action          String
  messageTemplate String?
  channel         String   @default("telegram")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model ManagerTask {
  id         String    @id @default(cuid())
  driverId   String
  type       String
  title      String
  priority   String    @default("medium")
  status     String    @default("open")
  triggerId  String?
  metadata   Json?
  createdBy  String?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  driver     Driver    @relation(fields: [driverId], references: [id])

  @@index([status, priority, createdAt(sort: Desc)])
  @@index([driverId])
}

model DailyParkStats {
  id                 String   @id @default(cuid())
  date               DateTime @unique @db.Date
  activeDrivers      Int      @default(0)
  totalTrips         Int      @default(0)
  driversAtRisk      Int      @default(0)
  sleepingDrivers    Int      @default(0)
  promotionsActive   Int      @default(0)
  profitableCount    Int      @default(0)
  mediumCount        Int      @default(0)
  smallCount         Int      @default(0)
  reactivatedDrivers Int      @default(0)
  createdAt          DateTime @default(now())
}

enum MessageDirection {
  inbound
  outbound
  system
}

enum AiStatus {
  pending    // входящее — ожидает обработки AI
  processing // AI обрабатывает
  done       // AI ответил или передал оператору
  skipped    // не требует обработки AI
  failed     // ошибка AI
}

enum ChatChannel {
  telegram
  whatsapp
  max
  yandex_pro
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum MessageType {
  text
  image
  audio
  video
  sticker
  voice
  document
  system
}

enum WhatsAppMessageType {
  chat
  image
  audio
  video
  sticker
  voice
  document
}

enum WhatsAppConnectionStatus {
  idle
  qr
  qr_expired
  authenticated
  ready
  disconnected
  error
}

enum AnalyticsEventType {
  USER_CREATED
  BOT_STARTED
  SURVEY_STARTED
  SURVEY_COMPLETED
  BROADCAST_SENT
  BROADCAST_FAILED
}

// ═══════════════════════════════════════════════════════════════════
// TASKS MODULE
// ═══════════════════════════════════════════════════════════════════

enum TaskSource {
  auto
  manual
  chat
}

enum TaskStatus {
  todo
  in_progress
  waiting_reply
  overdue
  snoozed
  done
  cancelled
  archived
}

enum TaskPriority {
  critical
  high
  medium
  low
}

model Task {
  id                    String       @id @default(cuid())
  driverId              String
  source                TaskSource   @default(manual)
  type                  String                          // e.g. "call_back", "check_docs", "inactive_followup"
  title                 String
  description           String?
  status                TaskStatus   @default(todo)
  priority              TaskPriority @default(medium)
  isActive              Boolean      @default(true)     // used in partial unique index

  // Trigger / Dedupe (for auto-tasks)
  triggerType           String?                          // business semantics: "driver_inactive"
  triggerKey            String?                          // specific computation: "inactive_3d_since_..."
  dedupeKey             String?                          // technical consolidation key

  // Scheduling
  dueAt                 DateTime?

  // Assignment
  assigneeId            String?
  createdBy             String?
  resolvedBy            String?

  // Chat linkage
  chatId                String?
  originMessageId       String?
  originExcerpt         String?
  originCreatedAt       DateTime?

  // Reactive sync flags
  hasNewReply           Boolean      @default(false)
  lastInboundMessageAt  DateTime?
  lastOutboundMessageAt DateTime?

  // Metadata
  metadata              Json?        @default("{}")

  // Timestamps
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  resolvedAt            DateTime?

  // Relations
  driver                Driver       @relation(fields: [driverId], references: [id])
  events                TaskEvent[]

  // Indexes
  @@index([driverId])
  @@index([status, priority, dueAt])
  @@index([isActive, source])
  @@index([chatId])
  @@index([assigneeId])

  @@map("tasks")
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  eventType String                          // e.g. "created", "status_changed", "message_sent", "reply_received"
  payload   Json?    @default("{}")
  actorType String?  @default("system")     // "system" | "user" | "auto"
  actorId   String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt(sort: Desc)])
  @@index([eventType])

  @@map("task_events")
}

// ═══════════════════════════════════════════════════════════════════
// AI CONTROL CENTER — Block 3.5
// ═══════════════════════════════════════════════════════════════════

enum AiAgentMode {
  off
  suggest_only
  auto_reply
  operator_locked
}

enum AiProviderType {
  anthropic
  openai
}

enum AiImportMode {
  from_connection_time
  available_history
  last_n_days
}

enum AiImportStatus {
  queued
  running
  completed
  partial
  failed
}

/// Единственная запись — настройки AI агента (upsert by id="singleton")
model AiAgentConfig {
  id                   String         @id @default("singleton")
  enabled              Boolean        @default(false)
  mode                 AiAgentMode    @default(off)
  provider             AiProviderType @default(anthropic)
  apiKeyEncrypted      String?
  classificationModel  String         @default("claude-haiku-4-5")
  responseModel        String         @default("claude-sonnet-4-5")
  language             String         @default("ru")
  confidenceThreshold  Float          @default(0.75)
  maxAutoRepliesPerChat Int           @default(5)
  activeChannels       String[]
  escalationPolicy     Json?          /// { alwaysEscalate: string[], neverAutoReply: string[] }
  workingHours         Json?          /// { enabled: bool, from: "09:00", to: "21:00", timezone: "Europe/Moscow" }
  routingRules         Json?          /// [{ condition, model }]
  promptRole           String?
  promptTone           String?
  promptAllowed        String?
  promptForbidden      String?
  connectionStatus     String?        /// "ok" | "error" | "unchecked"
  lastConnectionCheckAt DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

/// FAQ / База знаний агента
model KnowledgeBaseEntry {
  id              String    @id @default(cuid())
  title           String
  category        String    @default("general")
  sampleQuestions Json      @default("[]")
  answer          String
  tags            String[]
  channels        String[]
  active          Boolean   @default(true)
  priority        Int       @default(0)
  lastReviewedAt  DateTime?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, priority(sort: Desc)])
  @@index([category])
}

/// Журнал решений AI агента
model AiDecisionLog {
  id                   String   @id @default(cuid())
  messageId            String?
  chatId               String?
  channel              String?
  detectedIntent       String?
  confidence           Float?
  decision             String?  /// "auto_reply" | "escalate" | "skip"
  selectedModel        String?
  usedKnowledgeEntries Json?
  generatedReply       String?
  replySent            Boolean  @default(false)
  escalated            Boolean  @default(false)
  error                String?
  reviewedByOperator   Boolean  @default(false)
  operatorVerdict      String?  /// "good" | "bad" | "fixed"
  createdAt            DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([channel])
  @@index([detectedIntent])
  @@index([decision])
}

/// Задания на импорт истории из мессенджеров
model HistoryImportJob {
  id                String         @id @default(cuid())
  channels          String[]
  mode              AiImportMode
  daysBack          Int?
  status            AiImportStatus @default(queued)
  resultType        String?        /// "full" | "partial" | "live_only"
  startedAt         DateTime?
  finishedAt        DateTime?
  chatsScanned      Int            @default(0)
  contactsFound     Int            @default(0)
  messagesImported  Int            @default(0)
  coveredPeriodFrom DateTime?
  coveredPeriodTo   DateTime?
  detailsJson       Json?
  createdAt         DateTime       @default(now())

  @@index([status, createdAt(sort: Desc)])
}
