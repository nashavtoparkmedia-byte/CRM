generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiConnection {
  id        String   @id @default(cuid())
  clid      String
  apiKey    String
  parkId    String
  createdAt DateTime @default(now())
  logs      ApiLog[]
}

model ApiLog {
  id           String        @id @default(cuid())
  connectionId String
  method       String
  requestUrl   String
  requestBody  String?
  responseBody String?
  statusCode   Int
  error        String?
  durationMs   Int
  createdAt    DateTime      @default(now())
  connection   ApiConnection @relation(fields: [connectionId], references: [id])
}

model TelegramConnection {
  id            String   @id @default(cuid())
  apiId         Int
  apiHash       String
  sessionString String?
  isActive      Boolean  @default(false)
  phoneNumber   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isDefault     Boolean  @default(false)
  name          String?
}

model MaxConnection {
  id        String   @id
  name      String?
  botToken  String
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverMax {
  id                String   @id @default(cuid())
  driverId          String   @unique
  maxExternalUserId String?
  maxExternalChatId String?
  phone             String?
  name              String?
  createdAt         DateTime @default(now())
  driver            Driver   @relation(fields: [driverId], references: [id])

  @@index([maxExternalUserId])
  @@index([maxExternalChatId])
}

model MaxPersonalSession {
  id                      String               @id @default(cuid())
  historyImportMode       MaxHistoryImportMode @default(from_connection_time)
  connectedAt             DateTime?
  historySyncModeResolved MaxHistorySyncMode?
  historySyncStatus       MaxHistorySyncStatus @default(not_started)
  initialSyncCompletedAt  DateTime?
  isActive                Boolean              @default(true)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

model WhatsAppConnection {
  id          String                   @id @default(cuid())
  name        String?
  status      WhatsAppConnectionStatus @default(idle)
  phoneNumber String?
  sessionData String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  chats       WhatsAppChat[]
}

model WhatsAppChat {
  id            String             @id
  connectionId  String
  name          String?
  lastMessageAt DateTime?
  connection    WhatsAppConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages      WhatsAppMessage[]

  @@unique([id, connectionId])
}

model WhatsAppMessage {
  id            String              @id
  chatId        String
  body          String
  fromMe        Boolean
  timestamp     DateTime
  type          WhatsAppMessageType @default(chat)
  mediaPath     String?
  isMediaLoaded Boolean             @default(false)
  mediaSize     Int?
  chat          WhatsAppChat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([id, chatId])
}

// Persistent chat directory — survives WhatsAppChat/Message deletion.
// Used as anchor for Baileys fetchMessageHistory (backfill without QR re-scan).
// Populated on every incoming message + messaging-history.set events.
model WhatsAppChatRoster {
  id              String   @id @default(cuid())
  connectionId    String
  jid             String   // 79221853150@s.whatsapp.net (Baileys format)
  name            String?
  // Anchor for paginating BACKWARDS in time (available_history mode)
  oldestMsgKey    Json?    // serialized proto.IMessageKey
  oldestMsgTs     DateTime?
  // Anchor for last_n_days mode — start from newest and go backwards until cutoff
  newestMsgKey    Json?
  newestMsgTs     DateTime?
  lastSeen        DateTime @default(now())

  @@unique([connectionId, jid])
  @@index([connectionId])
  @@index([connectionId, newestMsgTs])
}

model DriverTelegram {
  id            String   @id @default(cuid())
  driverId      String   @unique
  telegramId    BigInt   @unique
  username      String?
  phoneVerified Boolean  @default(false)
  botState      String   @default("IDLE")
  carId         String?
  carLabel      String?
  createdAt     DateTime @default(now())
}

model BotChatMessage {
  id         String   @id @default(cuid())
  telegramId BigInt
  driverId   String?
  direction  String
  text       String
  createdAt  DateTime @default(now())
}

model Bot {
  id              String           @id @default(uuid())
  token           String           @unique
  name            String
  username        String?
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  analyticsEvents AnalyticsEvent[]
  broadcasts      Broadcast[]
  surveys         Survey[]
  users           User[]

  @@map("bots")
}

model Survey {
  id            String     @id @default(uuid())
  botId         String     @map("bot_id")
  title         String     @default("Новый опрос")
  triggerButton String     @default("📊 Опрос качества") @map("trigger_button")
  isActive      Boolean    @default(true) @map("is_active")
  isLinear      Boolean    @default(true) @map("is_linear")
  googleSheetId String?    @map("google_sheet_id")
  syncMode      String     @default("ON_COMPLETE") @map("sync_mode")
  createdAt     DateTime   @default(now()) @map("created_at")
  archivedAt    DateTime?  @map("archived_at")
  questions     Question[]
  bot           Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("surveys")
}

model Question {
  id           String   @id @default(uuid())
  surveyId     String   @map("survey_id")
  order        Int      @default(0)
  type         String
  text         String
  options      Json?
  isRequired   Boolean  @default(true) @map("is_required")
  isConversion Boolean  @default(false) @map("is_conversion")
  routingRules Json?    @map("routing_rules")
  answers      Answer[]
  survey       Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model User {
  id                String           @id @default(uuid())
  botId             String           @map("bot_id")
  telegramId        BigInt           @map("telegram_id")
  username          String?
  firstName         String?          @map("first_name")
  currentQuestionId String?          @map("current_question_id")
  status            String           @default("ACTIVE")
  createdAt         DateTime         @default(now()) @map("created_at")
  analyticsEvents   AnalyticsEvent[]
  answers           Answer[]
  bot               Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, telegramId])
  @@map("users")
}

model Answer {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  questionId String   @map("question_id")
  value      String
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("answers")
}

model AnalyticsEvent {
  id        String             @id @default(uuid())
  botId     String             @map("bot_id")
  userId    String?            @map("user_id")
  eventType AnalyticsEventType @map("event_type")
  sourceId  String?            @map("source_id")
  metadata  Json?
  createdAt DateTime           @default(now()) @map("created_at")
  bot       Bot                @relation(fields: [botId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id])

  @@index([botId, createdAt])
  @@index([botId, eventType, createdAt])
  @@map("analytics_events")
}

model Broadcast {
  id            String         @id @default(uuid())
  botId         String         @map("bot_id")
  text          String
  status        String         @default("PENDING")
  totalTargeted Int            @default(0) @map("total_targeted")
  createdAt     DateTime       @default(now()) @map("created_at")
  completedAt   DateTime?      @map("completed_at")
  stats         BroadcastStat?
  bot           Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("broadcasts")
}

model BroadcastStat {
  id           String    @id @default(uuid())
  broadcastId  String    @unique @map("broadcast_id")
  successCount Int       @default(0) @map("success_count")
  failedCount  Int       @default(0) @map("failed_count")
  broadcast    Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@map("broadcast_stats")
}

model Driver {
  id                   String               @id @default(cuid())
  yandexDriverId       String               @unique
  fullName             String
  phone                String?
  licenseNumber        String?
  lastExternalPark     String?
  lastFleetCheckAt     DateTime?
  lastFleetCheckStatus String?
  lastFleetCheckId     String?
  segment              String               @default("unknown")
  segmentOverride      String?
  statusOverride       String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  score                Float?
  dismissedAt          DateTime?
  hiredAt              DateTime?
  lastOrderAt          DateTime?
  customFields         Json?                @default("{}")
  primaryYandexId      String?              @unique
  chats                Chat[]
  communicationEvents  CommunicationEvent[]
  contactProfile       Contact?
  attentions           DriverAttention[]
  daySummaries         DriverDaySummary[]
  events               DriverEvent[]
  maxProfile           DriverMax?
  managerTasks         ManagerTask[]
  tasks                Task[]

  @@index([fullName])
  @@index([segment])
  @@index([primaryYandexId])
}

model Chat {
  id                String            @id @default(cuid())
  driverId          String?
  channel           ChatChannel
  externalChatId    String            @unique
  name              String?
  lastMessageAt     DateTime?
  unreadCount       Int               @default(0)
  metadata          Json?             @default("{}")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  requiresResponse  Boolean           @default(false)
  status            String            @default("new")
  contactId         String?
  contactIdentityId String?
  assignedToUserId  String?
  lastInboundAt     DateTime?
  lastOutboundAt    DateTime?
  chatType          String            @default("private")
  CallSession       CallSession[]
  contact           Contact?          @relation(fields: [contactId], references: [id])
  contactIdentity   ContactIdentity?  @relation(fields: [contactIdentityId], references: [id])
  driver            Driver?           @relation(fields: [driverId], references: [id])
  GroupVisibility   GroupVisibility[]
  messages          Message[]

  @@index([driverId])
  @@index([contactId])
  @@index([contactIdentityId])
  @@index([lastMessageAt(sort: Desc)])
  @@index([status])
  @@index([assignedToUserId])
  @@index([status, assignedToUserId])
  @@index([chatType])
}

model Message {
  id              String              @id @default(cuid())
  chatId          String
  direction       MessageDirection
  type            MessageType         @default(text)
  content         String
  status          MessageStatus       @default(sent)
  externalId      String?             @unique
  metadata        Json?               @default("{}")
  sentAt          DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  channel         ChatChannel?        @default(whatsapp)
  aiStatus        AiStatus?
  clientMessageId String?             @unique
  CallSession     CallSession?
  chat            Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  attachments     MessageAttachment[]
  eventLogs       MessageEventLog[]

  @@index([chatId, sentAt(sort: Desc)])
  @@index([externalId])
  @@index([aiStatus])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  type      String
  url       String
  fileName  String?
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessageEventLog {
  id        String   @id @default(cuid())
  messageId String
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
  status    String   @default("pending")
  updatedAt DateTime @updatedAt
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
  @@index([status, eventType])
}

model DriverEvent {
  id        String   @id @default(cuid())
  driverId  String
  eventType String
  payload   Json?
  createdBy String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])

  @@index([driverId, createdAt])
  @@index([eventType])
}

model DriverAttention {
  id         String    @id @default(cuid())
  driverId   String
  reason     String
  riskLevel  String    @default("medium")
  status     String    @default("open")
  meta       Json?
  createdBy  String?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  driver     Driver    @relation(fields: [driverId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([driverId])
}

model DriverDaySummary {
  id                String   @id @default(cuid())
  driverId          String
  date              DateTime @db.Date
  tripCount         Int      @default(0)
  hadManagerMessage Boolean  @default(false)
  hadManagerCall    Boolean  @default(false)
  hadAutoMessage    Boolean  @default(false)
  hadPromotion      Boolean  @default(false)
  hadAiAction       Boolean  @default(false)
  hadGoalAchieved   Boolean  @default(false)
  driver            Driver   @relation(fields: [driverId], references: [id])

  @@unique([driverId, date])
  @@index([date])
  @@index([driverId, date])
}

model ScoringThreshold {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Int
  updatedAt DateTime @updatedAt
}

model CommunicationEvent {
  id        String   @id @default(cuid())
  driverId  String
  channel   String
  direction String
  eventType String
  content   String?
  metadata  Json?
  createdBy String?
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id])

  @@index([driverId, createdAt(sort: Desc)])
  @@index([eventType])
}

model CommunicationTrigger {
  id              String   @id @default(cuid())
  name            String
  condition       String
  threshold       Int
  action          String
  messageTemplate String?
  channel         String   @default("telegram")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model ManagerTask {
  id         String    @id @default(cuid())
  driverId   String
  type       String
  title      String
  priority   String    @default("medium")
  status     String    @default("open")
  triggerId  String?
  metadata   Json?
  createdBy  String?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  driver     Driver    @relation(fields: [driverId], references: [id])

  @@index([status, priority, createdAt(sort: Desc)])
  @@index([driverId])
}

model DailyParkStats {
  id                 String   @id @default(cuid())
  date               DateTime @unique @db.Date
  activeDrivers      Int      @default(0)
  totalTrips         Int      @default(0)
  driversAtRisk      Int      @default(0)
  sleepingDrivers    Int      @default(0)
  promotionsActive   Int      @default(0)
  profitableCount    Int      @default(0)
  mediumCount        Int      @default(0)
  smallCount         Int      @default(0)
  reactivatedDrivers Int      @default(0)
  createdAt          DateTime @default(now())
}

/// Центральная сущность. Один Contact = один физический человек.
/// Связь с Driver (Яндекс) опциональна через yandexDriverId.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Contact {
  id                String            @id @default(cuid())
  displayName       String
  displayNameSource ContactNameSource @default(channel)
  masterSource      ContactSource     @default(chat)
  yandexDriverId    String?           @unique
  primaryPhoneId    String?
  notes             String?
  customFields      Json?             @default("{}")
  tags              String[]          @default([])
  isArchived        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  CallSession       CallSession[]
  chats             Chat[]
  driver            Driver?           @relation(fields: [yandexDriverId], references: [yandexDriverId])
  identities        ContactIdentity[]
  mergesAsMerged    ContactMerge[]    @relation("MergeMerged")
  mergesAsSurvivor  ContactMerge[]    @relation("MergeSurvivor")
  phones            ContactPhone[]
  tasks             Task[]

  @@index([displayName])
  @@index([isArchived])
}

/// Телефонный номер контакта. Хранится в E.164 (+79221234567).
model ContactPhone {
  id         String             @id @default(cuid())
  contactId  String
  phone      String
  label      String?
  isPrimary  Boolean            @default(false)
  source     ContactPhoneSource @default(manual)
  isActive   Boolean            @default(true)
  verifiedAt DateTime?
  createdAt  DateTime           @default(now())
  identities ContactIdentity[]
  contact    Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, phone])
  @@index([phone])
}

/// Идентификатор контакта в канале (telegramId, WA JID, maxUserId и т.д.)
model ContactIdentity {
  id                    String                @id @default(cuid())
  contactId             String
  channel               ChatChannel
  externalId            String
  phoneId               String?
  displayName           String?
  source                ContactIdentitySource @default(auto)
  confidence            Float                 @default(1.0)
  isActive              Boolean               @default(true)
  metadata              Json?                 @default("{}")
  createdAt             DateTime              @default(now())
  reachabilityCheckedAt DateTime?
  reachabilityStatus    ReachabilityStatus    @default(unknown)
  chats                 Chat[]
  contact               Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phone                 ContactPhone?         @relation(fields: [phoneId], references: [id])

  @@unique([channel, externalId])
  @@index([contactId])
  @@index([phoneId])
}

/// Аудит-лог операций склейки/расклейки контактов.
model ContactMerge {
  id             String      @id @default(cuid())
  survivorId     String
  mergedId       String
  action         MergeAction @default(merge)
  mergedBy       String      @default("system")
  reason         MergeReason
  confidence     Float?
  snapshotBefore Json
  createdAt      DateTime    @default(now())
  driverYandexId String?
  merged         Contact     @relation("MergeMerged", fields: [mergedId], references: [id])
  survivor       Contact     @relation("MergeSurvivor", fields: [survivorId], references: [id])

  @@index([survivorId])
  @@index([mergedId])
}

model Task {
  id                    String       @id @default(cuid())
  driverId              String
  source                TaskSource   @default(manual)
  type                  String
  title                 String
  description           String?
  status                TaskStatus   @default(todo)
  priority              TaskPriority @default(medium)
  isActive              Boolean      @default(true)
  triggerType           String?
  triggerKey            String?
  dedupeKey             String?
  dueAt                 DateTime?
  assigneeId            String?
  createdBy             String?
  resolvedBy            String?
  chatId                String?
  originMessageId       String?
  originExcerpt         String?
  originCreatedAt       DateTime?
  hasNewReply           Boolean      @default(false)
  lastInboundMessageAt  DateTime?
  lastOutboundMessageAt DateTime?
  metadata              Json?        @default("{}")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  resolvedAt            DateTime?
  contactId             String?
  scenario              String?
  stage                 String?
  stageEnteredAt        DateTime?
  nextActionAt          DateTime?
  slaDeadline           DateTime?
  closedReason          String?
  closedComment         String?
  scenarioData          Json?        @default("{}")
  events                TaskEvent[]
  contact               Contact?     @relation(fields: [contactId], references: [id])
  driver                Driver       @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([contactId])
  @@index([status, priority, dueAt])
  @@index([isActive, source])
  @@index([chatId])
  @@index([assigneeId])
  @@index([scenario, stage, isActive])
  @@index([driverId, scenario, isActive])
  @@index([slaDeadline])
  @@index([nextActionAt])
  @@map("tasks")
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  eventType String
  payload   Json?    @default("{}")
  actorType String?  @default("system")
  actorId   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("task_events")
}

model CrmUser {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("manager")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("crm_users")
}

/// Единственная запись — настройки AI агента (upsert by id="singleton")
model AiAgentConfig {
  id                    String         @id @default("singleton")
  enabled               Boolean        @default(false)
  mode                  AiAgentMode    @default(off)
  provider              AiProviderType @default(anthropic)
  apiKeyEncrypted       String?
  classificationModel   String         @default("claude-haiku-4-5")
  responseModel         String         @default("claude-sonnet-4-5")
  language              String         @default("ru")
  confidenceThreshold   Float          @default(0.75)
  maxAutoRepliesPerChat Int            @default(5)
  activeChannels        String[]
  /// { alwaysEscalate: string[], neverAutoReply: string[] }
  escalationPolicy      Json?
  /// { enabled: bool, from: "09:00", to: "21:00", timezone: "Europe/Moscow" }
  workingHours          Json?
  /// [{ condition, model }]
  routingRules          Json?
  promptRole            String?
  promptTone            String?
  promptAllowed         String?
  promptForbidden       String?
  /// "ok" | "error" | "unchecked"
  connectionStatus      String?
  lastConnectionCheckAt DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

/// FAQ / База знаний агента
model KnowledgeBaseEntry {
  id              String    @id @default(cuid())
  title           String
  category        String    @default("general")
  sampleQuestions Json      @default("[]")
  answer          String
  tags            String[]
  channels        String[]
  active          Boolean   @default(true)
  priority        Int       @default(0)
  lastReviewedAt  DateTime?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, priority(sort: Desc)])
  @@index([category])
}

/// Журнал решений AI агента
model AiDecisionLog {
  id                   String   @id @default(cuid())
  messageId            String?
  chatId               String?
  channel              String?
  detectedIntent       String?
  confidence           Float?
  /// "auto_reply" | "escalate" | "skip"
  decision             String?
  selectedModel        String?
  usedKnowledgeEntries Json?
  generatedReply       String?
  replySent            Boolean  @default(false)
  escalated            Boolean  @default(false)
  error                String?
  reviewedByOperator   Boolean  @default(false)
  /// "good" | "bad" | "fixed"
  operatorVerdict      String?
  createdAt            DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([channel])
  @@index([detectedIntent])
  @@index([decision])
}

/// Задания на импорт истории из мессенджеров
model HistoryImportJob {
  id                String         @id @default(cuid())
  channels          String[]
  mode              AiImportMode
  daysBack          Int?
  status            AiImportStatus @default(queued)
  /// "full" | "partial" | "live_only"
  resultType        String?
  startedAt         DateTime?
  finishedAt        DateTime?
  chatsScanned      Int            @default(0)
  contactsFound     Int            @default(0)
  messagesImported  Int            @default(0)
  coveredPeriodFrom DateTime?
  coveredPeriodTo   DateTime?
  detailsJson       Json?
  createdAt         DateTime       @default(now())
  connectionId      String?

  @@index([status, createdAt(sort: Desc)])
}

model CallSession {
  id              String           @id
  deviceId        String
  chatId          String?
  messageId       String?          @unique
  contactId       String?
  direction       MessageDirection
  callerNumber    String
  calleeNumber    String
  status          CallStatus       @default(ringing)
  startedAt       DateTime         @default(now())
  answeredAt      DateTime?
  endedAt         DateTime?
  duration        Int?
  disposition     CallDisposition?
  androidCallId   String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  Chat            Chat?            @relation(fields: [chatId], references: [id])
  Contact         Contact?         @relation(fields: [contactId], references: [id])
  TelephonyDevice TelephonyDevice  @relation(fields: [deviceId], references: [id])
  Message         Message?         @relation(fields: [messageId], references: [id])

  @@index([calleeNumber])
  @@index([callerNumber])
  @@index([chatId])
  @@index([contactId])
  @@index([deviceId, androidCallId])
  @@index([deviceId, startedAt(sort: Desc)])
  @@index([deviceId, status])
}

model GroupVisibility {
  id         String   @id
  userId     String
  chatId     String
  visibility String   @default("visible")
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([userId, chatId])
  @@index([userId])
}

model TelephonyCommand {
  id              String          @id
  deviceId        String
  type            String
  payload         Json
  status          CommandStatus   @default(pending)
  deliveredAt     DateTime?
  executedAt      DateTime?
  failedAt        DateTime?
  failReason      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  TelephonyDevice TelephonyDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId, status])
  @@index([status, createdAt])
}

model TelephonyDevice {
  id               String             @id
  androidId        String             @unique
  name             String
  phoneNumber      String?
  simOperator      String?
  status           DeviceStatus       @default(offline)
  isActive         Boolean            @default(true)
  revokedAt        DateTime?
  lastHeartbeat    DateTime?
  appVersion       String?
  deviceSecret     String             @unique
  fcmToken         String?
  metadata         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  CallSession      CallSession[]
  TelephonyCommand TelephonyCommand[]

  @@index([isActive])
  @@index([lastHeartbeat])
  @@index([status])
}

model config_change_log {
  id             Int      @id @default(autoincrement())
  parameter_name String
  previous_value String?
  new_value      String
  changed_at     DateTime @default(now()) @db.Timestamptz(6)
  changed_by     String?

  @@index([changed_at(sort: Desc)], map: "idx_config_change_log_time")
}

model cron_health_log {
  id            Int      @id @default(autoincrement())
  cron_name     String
  status        String   @default("ok")
  executed_at   DateTime @default(now()) @db.Timestamptz(6)
  duration_ms   Int      @default(0)
  error_message String?
  metadata      Json?

  @@index([cron_name, executed_at(sort: Desc)], map: "idx_cron_health_log_name_time")
}

model execution_lock {
  operation_name String   @id
  locked_at      DateTime @default(now()) @db.Timestamptz(6)
  expires_at     DateTime @db.Timestamptz(6)
  locked_by      String?
}

model health_score_history {
  id           Int      @id @default(autoincrement())
  manager_id   String
  score        Int
  health_level String
  recorded_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([manager_id, recorded_at(sort: Desc)], map: "idx_hsh_manager_date")
  @@index([manager_id, recorded_at(sort: Desc)], map: "idx_hsh_manager_time")
}

model health_snapshots {
  manager_id     String   @id
  score          Int
  decline_streak Int      @default(0)
  recorded_at    DateTime @default(now()) @db.Timestamptz(6)
}

model integrity_check_log {
  id              Int      @id @default(autoincrement())
  checked_at      DateTime @default(now()) @db.Timestamptz(6)
  duration_ms     Int      @default(0)
  total_issues    Int      @default(0)
  critical_issues Int      @default(0)
  warning_issues  Int      @default(0)
  details         Json?

  @@index([checked_at(sort: Desc)], map: "idx_integrity_check_log_time")
}

model intervention_actions {
  id              String   @id
  manager_id      String
  action          String
  comment         String?
  score_at_action Int?
  outcome         String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  @@index([manager_id, created_at(sort: Desc)], map: "idx_intervention_actions_manager")
}

model perf_log {
  id             Int      @id @default(autoincrement())
  operation_name String
  operation_type String   @default("other")
  duration_ms    Int
  is_slow        Boolean  @default(false)
  logged_at      DateTime @default(now()) @db.Timestamptz(6)
  metadata       Json?

  @@index([logged_at(sort: Desc)], map: "idx_perf_log_time")
}

model scenario_field_settings {
  id         String    @id
  scenarioId String
  fieldId    String
  showInList Boolean?
  showInCard Boolean?
  filterable Boolean?
  sortable   Boolean?
  groupable  Boolean?
  order      Int?
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedBy  String?

  @@unique([scenarioId, fieldId], map: "scenario_field_settings_unique")
  @@index([scenarioId], map: "scenario_field_settings_scenario_idx")
}

model stability_check_log {
  id            Int      @id @default(autoincrement())
  scope         String
  status        String
  checked_at    DateTime @default(now()) @db.Timestamptz(6)
  anomaly_count Int      @default(0)
  report        Json?

  @@index([checked_at(sort: Desc)], map: "idx_stability_check_log_time")
}

